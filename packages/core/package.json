{
  "name": "@fentaris/core",
  "version": "0.2.0",
  "description": "Fentaris MCP Proxy - Core",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./extensions": {
      "types": "./dist/extensions.d.ts",
      "import": "./dist/extensions.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsc --watch",
    "build": "tsc",
    "typecheck:extensions": "tsc -p tsconfig.extension-api.json",
    "test": "vitest run test",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "fentaris",
    "mcp",
    "proxy",
    "model-context-protocol"
  ],
  "author": "Gabriele Cipriani",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Fentaris/fentaris.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/Fentaris/fentaris#readme",
  "bugs": {
    "url": "https://github.com/Fentaris/fentaris/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "vitest": "^4.1.7"
  }
}
